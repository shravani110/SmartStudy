{
  "expo": {
    "name": "SmartStudy",
    "slug": "smart-study-app",
    "version": "1.0.0",
    "icon": "./assets/logo_scaled.jpeg",
    "scheme": "smartstudy",
    "assetBundlePatterns": [
      "**/*"
    ],
    "web": {
      "bundler": "metro"
    },
    "android": {
      "package": "com.anonymous.smartstudyquizgenerator",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_scaled.jpeg",
        "backgroundColor": "#FFFFFF"
      },
      "splash": {
        "image": "./assets/logo_scaled.jpeg",
        "resizeMode": "contain",
        "backgroundColor": "#FFFFFF"
      }
    },
    "extra": {
      "eas": {
        "projectId": "3b86b84a-9a40-4a7a-bb00-dc5065a6d816"
      }
    },
    "plugins": [
      "@react-native-google-signin/google-signin"
    ]
  }
}
